PORT=8080
BETTER_AUTH_SECRET=change-me-min-32-chars-long-secret!!
BETTER_AUTH_API_KEY=your-better-auth-api-key
# BETTER_AUTH_API_URL=https://api.betterauth.com
BETTER_AUTH_URL=http://localhost:8080
APP_NAME=Hesapport

# Resend — https://resend.com/docs/introduction
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Hesapport <onboarding@resend.dev>
# Production: verify domain at https://resend.com/domains and use noreply@yourdomain.com
# EMAIL_SEND_IN_DEV=false
CORS_ORIGIN=http://localhost:5173
ADMIN_CORS_ORIGIN=http://localhost:5174
DATABASE_URL=postgresql://hesapport:hesapport@localhost:5432/hesapport

# Same device, multiple accounts — https://better-auth.com/docs/plugins/multi-session
MULTI_SESSION_MAXIMUM_SESSIONS=10

# Teams — https://better-auth.com/docs/plugins/organization#teams
ORG_MAXIMUM_TEAMS=10
ORG_ALLOW_REMOVING_ALL_TEAMS=false
ORG_DEFAULT_TEAM_NAME=Ana Şube

# Default platform admin (full Better Auth admin role)
ADMIN_EMAIL=admin@hesapport.local
ADMIN_PASSWORD=HesapportAdmin1!
ADMIN_NAME=System Admin
